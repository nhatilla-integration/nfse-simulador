# Renomeie este arquivo para .env e preencha com seus dados reais

# PostgreSQL (dados de cadastro - emitente/cliente)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=sua_senha_aqui
PG_DATABASE=nfse_simulador
# true se o Postgres exigir SSL (Neon, Render, etc). Deixe false/vazio para Postgres local.
PG_SSL=false

# MongoDB (log/historico de emissao)
# Se usar MongoDB Atlas (nuvem, gratuito), cole a connection string completa aqui.
# Se usar o Mongo local do docker-compose, use: mongodb://mongo:27017/nfse_simulador
MONGO_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/nfse_simulador

PORT=3000

# Nivel de log do Pino: fatal, error, warn, info, debug, trace
LOG_LEVEL=info
